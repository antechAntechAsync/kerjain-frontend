# ============================================================
# KerjaIn Frontend — Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# Laravel API (Student + Professional)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Express Admin API
VITE_ADMIN_API_BASE_URL=http://localhost:3001/api/v1/admin

# Google OAuth
VITE_GOOGLE_AUTH_URL=http://localhost:8000/api/v1/auth/google

# Application
VITE_APP_NAME=KerjaIn
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173

# Feature Flags
VITE_ENABLE_DEBUG_MODE=false

# Analytics (Optional)
VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=
